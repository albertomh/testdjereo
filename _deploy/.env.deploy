DEBUG=false
SECRET_KEY="django-insecure_not-a-secret"
ALLOWED_HOSTS=<vps-IP-address>
# CSRF_TRUSTED_ORIGINS entries must include both scheme and hostname
CSRF_TRUSTED_ORIGINS=https://example.com
# TODO: remember to set {password} in the DATABASE_URL connection string
USE_SQLITE=true
DATABASE_URL="postgres://testdjereo:{password}@localhost:5432/testdjereo"
